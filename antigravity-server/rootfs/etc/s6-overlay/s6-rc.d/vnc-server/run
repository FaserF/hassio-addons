#!/command/with-contenv bashio
# shellcheck shell=bash
# ==============================================================================
# Home Assistant App: Antigravity-Server
# Runs the TigerVNC server
# ==============================================================================

bashio::log.info "Starting TigerVNC server on display :1..."

# Start VNC server as dev user
exec gosu dev vncserver :1 \
    -localhost no \
    -geometry 1920x1080 \
    -depth 24 \
    -fg \
    -SecurityTypes VncAuth,TLSVnc \
    -rfbauth /home/dev/.config/tigervnc/passwd
