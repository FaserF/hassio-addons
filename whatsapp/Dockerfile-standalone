# Only for Docker (cannot be used as HA addon)
FROM node:24-alpine

# Install build dependencies, git, and media tools
RUN apk add --no-cache \
    git \
    curl \
    dos2unix \
    ffmpeg \
    build-base \
    python3

# Create persistent data directory and application directory
RUN mkdir -p /data /opt/whatsapp && \
    chown -R node:node /data /opt/whatsapp

WORKDIR /opt/whatsapp

# Copy ONLY the node application code and readme (bypasses rootfs/bashio completely)
COPY --chown=node:node app/ ./
COPY --chown=node:node README.md ./

# Install npm dependencies (including @whiskeysockets/baileys from package.json)
RUN rm -rf package-lock.json node_modules && \
    npm install --no-audit --no-fund --legacy-peer-deps

EXPOSE 8066

# Run as non-root user
USER node

CMD ["node", "index.js"]

HEALTHCHECK --interval=30s --timeout=5s --start-period=10s --retries=3 \
    CMD curl --fail -s http://127.0.0.1:8066/health || exit 1

# Labels
ARG BUILD_DATE
LABEL org.opencontainers.image.title="WhatsApp Gateway" \
      org.opencontainers.image.description="Home Assistant WhatsApp App (Baileys/Node.js) - Standalone Container." \
      org.opencontainers.image.vendor="FaserF's Home Assistant Apps" \
      org.opencontainers.image.authors="FaserF <https://github.com/FaserF>" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.url="https://github.com/FaserF/ha-whatsapp" \
      org.opencontainers.image.source="https://github.com/FaserF/ha-whatsapp" \
      org.opencontainers.image.documentation="https://github.com/FaserF/ha-whatsapp/blob/master/whatsapp/README.md" \
      org.opencontainers.image.created="${BUILD_DATE}"
