#!/usr/bin/with-contenv bash
if [ -f /run/ABORT_STARTUP ]; then exit 0; fi

# make our folders
mkdir -p \
  /assets \
  /config/nginx/site-confs \
  /config/log/nginx \
  /run \
  /var/lib/nginx/tmp/client_body \
  /var/tmp/nginx

# copy config files
if [[ ! -f /config/nginx/nginx.conf ]]; then
  bashio::log.info "Copying default nginx.conf to /config/nginx/nginx.conf"
  cp /defaults/nginx.conf /config/nginx/nginx.conf
fi

if [[ ! -f /config/nginx/site-confs/default ]]; then
  bashio::log.info "Copying default site config to /config/nginx/site-confs/default"
  cp /defaults/default /config/nginx/site-confs/default
fi

# Check if the default nginx config listens on port 85 (to avoid conflict with webapp on 3000)
# If it doesn't (or if it's the old default listening on 80/default), replace it
if ! grep -q "listen 85" /config/nginx/site-confs/default; then
    bashio::log.warning "Default nginx config does not listen on port 85. Updating to prevent conflict..."
    mv /config/nginx/site-confs/default /config/nginx/site-confs/default.bak
    cp /defaults/default /config/nginx/site-confs/default
fi

# Ownership
# Use -h to change ownership of symlinks themselves, and -R to recurse
# We also want to make sure the target directory is owned by abc if it's a symlink
chown -R abc:abc /assets
chown -R abc:abc /config

# If /config or /assets are symlinks, ensure the target is also owned by abc
# (This is important if the target is on a different mount/filesystem)
for dir in /assets /config; do
    if [ -L "$dir" ]; then
        target=$(readlink -f "$dir")
        bashio::log.debug "Ensuring ownership of symlink target: $target"
        chown -R abc:abc "$target"
    fi
done